SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
AGENT_IMAGE=cerberus-agent:dev
IDLE_TIMEOUT_MS=1800000
MAX_CONCURRENT_AGENTS=50
LOG_LEVEL=info

# Console auth. Leave empty for a machine only you can reach; set a value before exposing
# port 8080 to anyone else — the console can stop/restart agents and read every conversation.
DASHBOARD_TOKEN=
